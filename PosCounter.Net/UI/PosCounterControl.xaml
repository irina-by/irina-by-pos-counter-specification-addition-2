<UserControl x:Class="PosCounter.Net.UI.PosCounterControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="360"
             MinHeight="0"
             FontFamily="Segoe UI"
             FontSize="11"
             FontWeight="Normal"
             Background="#F5F5F5">
    <UserControl.Resources>
        <SolidColorBrush x:Key="ToolbarBg" Color="#E9ECEF"/>
        <SolidColorBrush x:Key="HeaderBlue" Color="#2C3E66"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="GroupBg" Color="#E2E8F0"/>
        <Style x:Key="AppButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#2C5F8A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}" CornerRadius="20" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Footer: one horizontal row in palette; buttons share width. -->
        <Style x:Key="ExportFooterButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource AppButtonStyle}">
            <Setter Property="Padding" Value="6,6"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="MinHeight" Value="36"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar (DockPanel has no Padding in WPF; use Border for inset) -->
        <Border Grid.Row="0" Background="{StaticResource ToolbarBg}" Padding="16,12,16,8">
            <DockPanel LastChildFill="False">
                <Button x:Name="BtnRun" Style="{StaticResource AppButtonStyle}" Content="ЗАПУСТИТЬ" Width="130" Click="BtnRun_OnClick"/>
                <Button x:Name="BtnSelectSpec" Style="{StaticResource AppButtonStyle}" Content="Выбрать спецификацию" Margin="10,0,0,0" Padding="10,5" Click="BtnSelectSpec_OnClick"/>
                <Button x:Name="BtnReset" Style="{StaticResource AppButtonStyle}" Content="Сброс" Margin="10,0,0,0" Background="#6C757D" Click="BtnReset_OnClick"/>
                <Border Background="White" CornerRadius="32" Margin="16,0,0,0" Padding="12,5" BorderBrush="#DDDDDD" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox x:Name="ChkAllInModel" VerticalAlignment="Center" Checked="ChkAllInModel_OnChanged" Unchecked="ChkAllInModel_OnChanged"/>
                        <TextBlock Text="Все объекты в модели" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <!-- Filters row (Grid has no Padding in WPF; use Border for inset) -->
        <Border Grid.Row="1" Background="White" Padding="16,10,16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="160"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnFilterText" Style="{StaticResource AppButtonStyle}" Grid.Column="0" HorizontalAlignment="Stretch" Background="#F0F2F5" Foreground="#222"
                        Content="Марка  ▼" Click="BtnFilterText_OnClick"/>
                <Button x:Name="BtnFilterName" Style="{StaticResource AppButtonStyle}" Grid.Column="2" HorizontalAlignment="Stretch" Background="#F0F2F5" Foreground="#222"
                        Content="Наименование  ▼" Click="BtnFilterName_OnClick"/>
                <Button x:Name="BtnFilterCount" Style="{StaticResource AppButtonStyle}" Grid.Column="4" HorizontalAlignment="Stretch" Background="#F0F2F5" Foreground="#222"
                        Content="Количество  ▼" Click="BtnFilterCount_OnClick"/>
                <Button x:Name="BtnFilterLayer" Style="{StaticResource AppButtonStyle}" Grid.Column="6" HorizontalAlignment="Stretch" Background="#F0F2F5" Foreground="#222"
                        Content="Слой  ▼" Click="BtnFilterLayer_OnClick"/>

                <!-- Popups -->
                <Popup x:Name="PopupFilterText" PlacementTarget="{Binding ElementName=BtnFilterText}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                    <Border Background="White" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="8" Padding="8" MinWidth="320" MaxHeight="240">
                        <!-- Use Grid (not StackPanel) so ScrollViewer gets constrained height and can scroll -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <CheckBox x:Name="ChkFilterTextAll" Grid.Row="0" Content="Все" Margin="0,0,0,6" Click="ChkFilterTextAll_OnClick"/>
                            <TextBox x:Name="TxtSearchText" Grid.Row="1" Margin="0,0,0,6" TextChanged="TxtSearchText_OnTextChanged"/>
                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl x:Name="ListFilterText"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Popup>
                <Popup x:Name="PopupFilterName" PlacementTarget="{Binding ElementName=BtnFilterName}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                    <Border Background="White" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="8" Padding="8" MinWidth="320" MaxHeight="240">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <CheckBox x:Name="ChkFilterNameAll" Grid.Row="0" Content="Все" Margin="0,0,0,6" Click="ChkFilterNameAll_OnClick"/>
                            <TextBox x:Name="TxtSearchName" Grid.Row="1" Margin="0,0,0,6" TextChanged="TxtSearchName_OnTextChanged"/>
                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl x:Name="ListFilterName"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Popup>
                <Popup x:Name="PopupFilterCount" PlacementTarget="{Binding ElementName=BtnFilterCount}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                    <Border Background="White" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="8" Padding="8" MinWidth="220" MaxHeight="240">
                        <!-- Use Grid (not StackPanel) so ScrollViewer gets constrained height and can scroll -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <CheckBox x:Name="ChkFilterCountAll" Grid.Row="0" Content="Все" Margin="0,0,0,6" Click="ChkFilterCountAll_OnClick"/>
                            <TextBox x:Name="TxtSearchCount" Grid.Row="1" Margin="0,0,0,6" TextChanged="TxtSearchCount_OnTextChanged"/>
                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl x:Name="ListFilterCount"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Popup>
                <Popup x:Name="PopupFilterLayer" PlacementTarget="{Binding ElementName=BtnFilterLayer}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                    <Border Background="White" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="8" Padding="8" MinWidth="220" MaxHeight="240">
                        <!-- Use Grid (not StackPanel) so ScrollViewer gets constrained height and can scroll -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <CheckBox x:Name="ChkFilterLayerAll" Grid.Row="0" Content="Все" Margin="0,0,0,6" Click="ChkFilterLayerAll_OnClick"/>
                            <TextBox x:Name="TxtSearchLayer" Grid.Row="1" Margin="0,0,0,6" TextChanged="TxtSearchLayer_OnTextChanged"/>
                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl x:Name="ListFilterLayer"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Popup>
            </Grid>
        </Border>

        <!-- Table -->
        <Border Grid.Row="2" Margin="16,12,16,12" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12">
            <!-- No GroupStyle/Expander: grouped DataGrid inside ElementHost palettes is a common native crash source in AutoCAD. Rows are sorted by Layer in code-behind. -->
            <DataGrid x:Name="GridResults"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      MinHeight="120"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      CanUserResizeColumns="True"
                      CanUserReorderColumns="False"
                      CanUserSortColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      EnableRowVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      LoadingRow="GridResults_OnLoadingRow"
                      SelectionChanged="GridResults_OnSelectionChanged">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="White"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSummary}" Value="True">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Background" Value="#EDF2F7"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Resources>
                    <Style TargetType="{x:Type DataGridColumnHeader}">
                        <Setter Property="Background" Value="#D9E1EC"/>
                        <Setter Property="Padding" Value="8,8"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="40" MinWidth="36" IsReadOnly="False">
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <CheckBox x:Name="ChkSelectAllVisible" Click="ChkSelectAllVisible_OnClick"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox Click="RowCheckBox_OnClick" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <CheckBox.Style>
                                        <Style TargetType="CheckBox">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSummary}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </CheckBox.Style>
                                    <CheckBox.IsChecked>
                                        <Binding Path="Data.IsChecked" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged"/>
                                    </CheckBox.IsChecked>
                                </CheckBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Марка" Width="*" MinWidth="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Text}" Margin="4,2" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Наименование" Width="2*" MinWidth="220" IsReadOnly="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Data.NameFromSpec, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         MinHeight="24"
                                         Margin="2,2"
                                         VerticalAlignment="Top"
                                         BorderThickness="0"
                                         Background="Transparent">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSummary}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Количество" Width="110" MinWidth="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Count}" Margin="4,2" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Слой" Width="*" MinWidth="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Layer}" Margin="4,2" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Bottom bar (Grid has no Padding in WPF; use Border for inset) -->
        <Border Grid.Row="3" Background="#F8F9FA" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,1,1,0" Padding="12,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" TextWrapping="Wrap" Foreground="#222">
                    <Run Text="Всего строк: "/>
                    <Run x:Name="LblTotalRows" Text="0"/>
                    <Run Text="  Выделено: "/>
                    <Run x:Name="LblSelectedRows" Text="0"/>
                    <Run Text="  Видимых: "/>
                    <Run x:Name="LblVisibleRows" Text="0"/>
                    <Run Text="  В таблице (Ctrl): "/>
                    <Run x:Name="LblTableSelectionRows" Text="0"/>
                    <Run Text="  Σ кол-во: "/>
                    <Run x:Name="LblTableSelectionSum" Text="0"/>
                    <Run Text="  "/>
                    <Run x:Name="StatusText" Text="" Foreground="#334"/>
                </TextBlock>

                <UniformGrid Grid.Row="2" Rows="1" Columns="4" Margin="0,2,0,0">
                    <Button x:Name="BtnShowOnDrawing" Style="{StaticResource ExportFooterButtonStyle}" Background="#5B4F96" Margin="0,0,5,6" Click="BtnShowOnDrawing_OnClick">
                        <TextBlock TextAlignment="Center" TextWrapping="Wrap" TextTrimming="CharacterEllipsis">Показать на чертеже</TextBlock>
                    </Button>
                    <Button x:Name="BtnExportAll" Style="{StaticResource ExportFooterButtonStyle}" Background="#1E5F8E" Margin="0,0,5,6" Click="BtnExportAll_OnClick">
                        <TextBlock TextAlignment="Center" TextWrapping="Wrap" TextTrimming="CharacterEllipsis">ЭКСПОРТ В EXCEL</TextBlock>
                    </Button>
                    <Button x:Name="BtnExportSelected" Style="{StaticResource ExportFooterButtonStyle}" Background="#2D6A4F" Margin="0,0,5,6" Click="BtnExportSelected_OnClick">
                        <TextBlock TextAlignment="Center" TextWrapping="Wrap" TextTrimming="CharacterEllipsis">✅ Экспорт выделенных</TextBlock>
                    </Button>
                    <Button x:Name="BtnExportVisible" Style="{StaticResource ExportFooterButtonStyle}" Background="#2D6A4F" Margin="0,0,0,6" Click="BtnExportVisible_OnClick">
                        <TextBlock TextAlignment="Center" TextWrapping="Wrap" TextTrimming="CharacterEllipsis">📄 Экспорт видимых</TextBlock>
                    </Button>
                </UniformGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
